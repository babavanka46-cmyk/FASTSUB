{
  "manifest_version": 3,
  "name": "FASTSUB Gemini Bridge",
  "version": "0.1.0",
  "description": "Correct FASTSUB subtitle JSON with Gemini while preserving timestamps.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "FASTSUB"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:8100/*",
    "http://127.0.0.1:8100/*",
    "https://generativelanguage.googleapis.com/*"
  ]
}
